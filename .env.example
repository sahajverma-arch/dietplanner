# Supabase — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — ONLY needed locally to run `npm run seed:foods`
# (writes the foods reference table). Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NVIDIA NIM — create a key at https://build.nvidia.com (server-side only, never exposed to the browser)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Counselling sheet sync (Today's Activity tab)
# Preferred: private access via a Google service account that the sheet is
# shared with (Viewer). Enable the Google Sheets API in the same GCP project.
GOOGLE_SERVICE_ACCOUNT_EMAIL=sheet-sync@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
COUNSELLING_SHEET_ID=your-sheet-id
# COUNSELLING_SHEET_RANGE=Raw_Counselling
# Fallback (only works while the sheet is link-viewable):
# COUNSELLING_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv&gid=0
# Shared secret QStash sends to /api/sync-counselling (x-cron-secret header or ?secret=)
CRON_SECRET=

# Optional overrides
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Used automatically when the primary model is congested/unavailable.
# If llama-3.1-70b is slow (shared free endpoint), a good fast primary is:
#   NVIDIA_MODEL=mistralai/mistral-small-4-119b-2603
# NVIDIA_FALLBACK_MODEL=meta/llama-3.1-8b-instruct
