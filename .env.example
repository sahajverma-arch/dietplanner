# Supabase — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — ONLY needed locally to run `npm run seed:foods`
# (writes the foods reference table). Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NVIDIA NIM — create a key at https://build.nvidia.com (server-side only, never exposed to the browser)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Used automatically when the primary model is congested/unavailable.
# If llama-3.1-70b is slow (shared free endpoint), a good fast primary is:
#   NVIDIA_MODEL=mistralai/mistral-small-4-119b-2603
# NVIDIA_FALLBACK_MODEL=meta/llama-3.1-8b-instruct
